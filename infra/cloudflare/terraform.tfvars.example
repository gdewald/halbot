# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars.

cloudflare_account_id = "REPLACE_WITH_ACCOUNT_ID"
cloudflare_zone_id    = "REPLACE_WITH_ZONE_ID"
apex_domain           = "example.com"

# Optional overrides:
# subdomain        = "stats"
# bucket_name      = "halbot-stats"
# r2_location_hint = ""   # one of: wnam, enam, weur, eeur, apac, or "" for auto
