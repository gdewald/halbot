DISCORD_TOKEN=your_discord_bot_token_here
LMSTUDIO_URL=http://localhost:1234/v1/chat/completions
LOG_LEVEL=INFO
# Override the default model used in LMStudio
#LMSTUDIO_MODEL=google/gemma-4-e2b

# Skip the Hugging Face revision check on startup (saves ~200ms and works offline).
# Only set this after the whisper model has been downloaded at least once.
# Cached models live at %USERPROFILE%\.cache\huggingface\hub
#HF_HUB_OFFLINE=1

# Merge voice wake-word detection + intent parsing into a single LLM call
# (default: true).  Saves one round-trip per voice utterance.  Set false
# to use two sequential calls (wake classifier, then intent parser only
# when the wake word fired) — useful for debugging either stage alone.
#VOICE_LLM_COMBINE_CALLS=true

# Auto-leave a voice channel after it has had no non-bot members for this
# many seconds.  Default: 1800 (30 minutes).  Set to 0 to disable and stay
# connected indefinitely.
#VOICE_IDLE_TIMEOUT_SECONDS=1800

# Per-guild rolling voice-command history, bounded by turn count.  A "turn"
# is one (user transcript, bot response) pair.  Persisted in SQLite so
# history survives bot restarts.  Set to 0 to disable history entirely
# (voice LLM calls become stateless).  Default: 10.
#VOICE_HISTORY_TURNS=10

# --- Text-to-speech -------------------------------------------------------
# When the bot is connected to a voice channel, replies are spoken via the
# configured TTS engine instead of posted to the text channel.  Fallbacks to
# text when no engine is available or the bot isn't in voice.
#
# TTS_ENGINE — which backend to use.  Options:
#   kokoro   — Kokoro-82M, local, ~300 MB VRAM, Apache 2.0 (default)
#   none     — disable TTS entirely, always post text
#   (future) xtts — Coqui XTTS v2, local, ~2–3 GB VRAM, voice cloning
#TTS_ENGINE=kokoro

# Kokoro-specific knobs (ignored for other engines).  Full voice list:
# https://huggingface.co/hexgrad/Kokoro-82M
#KOKORO_VOICE=af_heart
#KOKORO_LANG=a            # a=American English, b=British English, j=Japanese, …
#KOKORO_SPEED=1.0         # 0.5–2.0; 1.0 is natural pace
