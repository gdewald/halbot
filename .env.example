DISCORD_TOKEN=your_discord_bot_token_here
LMSTUDIO_URL=http://localhost:1234/v1/chat/completions
LOG_LEVEL=INFO

# Skip the Hugging Face revision check on startup (saves ~200ms and works offline).
# Only set this after the whisper model has been downloaded at least once.
# Cached models live at %USERPROFILE%\.cache\huggingface\hub
#HF_HUB_OFFLINE=1
