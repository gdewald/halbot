DISCORD_TOKEN=your_discord_bot_token_here
LMSTUDIO_URL=http://localhost:1234/v1/chat/completions
LOG_LEVEL=INFO

# Skip the Hugging Face revision check on startup (saves ~200ms and works offline).
# Only set this after the whisper model has been downloaded at least once.
# Cached models live at %USERPROFILE%\.cache\huggingface\hub
#HF_HUB_OFFLINE=1

# Strip reasoning/thinking tokens from every LLM call (default: true).
# "Thinking" models (Qwen3, Gemma thinking variants, DeepSeek-R1) emit
# hundreds of chain-of-thought tokens before answering, which dominates
# voice pipeline latency.  Set false if you want to keep thinking on.
#LLM_DISABLE_THINKING=true

# Merge voice wake-word detection + intent parsing into a single LLM call
# (default: true).  Saves one round-trip per voice utterance.  Set false
# to use two sequential calls (wake classifier, then intent parser only
# when the wake word fired) — useful for debugging either stage alone.
#VOICE_LLM_COMBINE_CALLS=true

# Auto-leave a voice channel after it has had no non-bot members for this
# many seconds.  Default: 1800 (30 minutes).  Set to 0 to disable and stay
# connected indefinitely.
#VOICE_IDLE_TIMEOUT_SECONDS=1800
